# RiceQuant (米筐) credentials
# 方式一：License Key（推荐）
RQDATA_LICENSE_KEY=your_license_key
# 方式二：用户名 + 密码
RQDATA_USERNAME=your_email
RQDATA_PASSWORD=your_token

# Tushare credentials
TUSHARE_TOKEN=your_token

# AKShare (无API Key，仅免费数据源)

# 迅投 (Xuntou) - 迅投终端账号密码
XUNTOU_USER=
XUNTOU_PASSWORD=

# iTick credentials
ITICK_TOKEN=
